#!/bin/bash
# commit-msg: enforce Conventional Commits format
commit_msg=$(cat "$1")

# Allow merge commits and fixup commits
echo "$commit_msg" | grep -qE '^(Merge|fixup!|squash!) ' && exit 0

pattern='^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\(.{1,30}\))?(!)?: .{1,100}$'

if ! echo "$commit_msg" | head -1 | grep -qE "$pattern"; then
    echo ""
    echo "FAIL: commit message must follow Conventional Commits"
    echo "Format:  type(scope): description"
    echo "Types:   feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert"
    echo "Example: feat(cart): add item quantity validation"
    echo "Breaking: feat(auth)!: remove legacy token endpoint"
    echo ""
    exit 1
fi
exit 0
